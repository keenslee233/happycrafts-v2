// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  role                String?
}

model Inventory {
  id              Int     @id @default(autoincrement())
  sku             String  @unique
  productName     String
  description     String?
  imageUrl        String?
  stockLevel      Int
  retailProductId String?
  masterStoreId   String?
  masterCostPrice Float?
  isListed        Boolean @default(false)
  isPublic        Boolean @default(false)
}

model PushedOrder {
  id                 Int      @id @default(autoincrement())
  retailOrderId      String   @unique
  masterDraftOrderId String
  shop               String   // Retail shop that sent the order
  masterStoreId      String?  // Master shop that received the order
  totalItems         Int
  totalAmount        Float
  customerEmail      String?
  shippingCity       String?
  createdAt          DateTime @default(now())
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  shop      String
  sku       String
  status    String   // 'SUCCESS', 'FAILED', 'BROADCAST'
  message   String
  createdAt DateTime @default(now())
}

model ProductMapping {
  id              String   @id @default(uuid())
  masterSku       String
  retailShop      String
  retailProductId String
  retailVariantId String
  retailSku       String?
  createdAt       DateTime @default(now())

  @@unique([masterSku, retailShop])
}

model PricingRule {
  id       String  @id @default(uuid())
  shop     String  @unique
  enabled  Boolean @default(false)
  mode     String  @default("multiplier") // "multiplier" or "fixed"
  value    Float   @default(1.0)
  rounding String  @default("none")       // "none", ".99", ".95", ".00"
}
